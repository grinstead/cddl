{
  "name": "@grinstead/cddl",
  "version": "0.1.0",
  "description": "Validate and parse Concise Data Definition Language (CDDL) files",
  "type": "module",
  "bin": {
    "cddl": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/grammar"
  ],
  "scripts": {
    "generate:peggy": "node scripts/build-peggy-from-abnf.mjs",
    "generate:parser": "npm run generate:peggy && node scripts/build-parser.mjs",
    "build": "npm run generate:parser && tsc -p tsconfig.json && node scripts/copy-generated-runtime.mjs",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "cddl",
    "cbor",
    "rfc8610",
    "parser"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "abnf": "^5.0.4",
    "peggy": "^5.0.6",
    "typescript": "^5.9.2"
  }
}
